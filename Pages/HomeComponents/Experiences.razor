@using BlazorDeploy.Models
@using BlazorDeploy.Services
@using Microsoft.Extensions.Localization
@inject IPortfolioService PortfolioService
@inject IStringLocalizer<BlazorDeploy.Resources.App> Loc

<section id="experiencias" class="section">
    <div class="container">
        <h2 class="fw-bold mb-5">
            <i class="fa-solid fa-briefcase me-2"></i>@Loc["Lbl_Experiences"]
        </h2>

        @if (ListExperiences == null || !ListExperiences.Any())
        {
            <div class="text-center p-5">
                <div class="spinner-border text-light" role="status"></div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="nav flex-column nav-pills shadow-lg rounded p-2 bg-dark" id="v-pills-tab" role="tablist">
                        @foreach (var exp in ListExperiences)
                        {
                            <button class="nav-link text-start text-white mb-2 custom-pill @(exp == ListExperiences.First() ? "active" : "")"
                                    id="tab-@exp.Id" data-bs-toggle="pill" data-bs-target="#content-@exp.Id"
                                    type="button" role="tab">
                                <div class="d-flex justify-content-between">
                                    <strong>@exp.CompanyName</strong>
                                    @if (exp.IsCurrent)
                                    {
                                        <span class="badge bg-primary">@Loc["Lbl_Current"]</span>
                                    }
                                </div>
                                <small class="opacity-75">
                                    @exp.PeriodStart.ToString("MM/yyyy") - @(exp.IsCurrent? Loc["Lbl_Current"] : exp.PeriodEnd?.ToString("MM/yyyy"))
                                </small>
                            </button>
                        }
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="tab-content bg-white p-4 rounded shadow-lg border-0" id="v-pills-tabContent">
                        @foreach (var exp in ListExperiences)
                        {
                            <div class="tab-pane fade @(exp == ListExperiences.First() ? "show active" : "")"
                                 id="content-@exp.Id" role="tabpanel">
                                
                                <div class="mb-4">
                                    <h3 class="fw-bold text-black mb-1">@exp.DisplayRole</h3>
                                    <span class="text-muted">@exp.CompanyName</span>
                                </div>

                                @if (!string.IsNullOrEmpty(exp.DisplayNotes))
                                {
                                    <div class="personal-insight mb-4 p-3 border-start border-4 border-primary bg-light">
                                        <i class="fa-solid fa-quote-left text-primary me-2"></i>
                                        <span class="fst-italic text-secondary">@exp.DisplayNotes</span>
                                    </div>
                                }

                                <h5 class="section-subtitle">@Loc["Lbl_Contributions"]</h5>
                                <ul class="list-unstyled mb-4">
                                    @foreach (var item in exp.DisplayContributions)
                                    {
                                        <li class="mb-2 d-flex align-items-start">
                                            <i class="fa-solid fa-check-circle text-primary mt-1 me-2"></i>
                                            <span class="text-dark">@item</span>
                                        </li>
                                    }
                                </ul>

                                @if (exp.DisplayHighlights.Any())
                                {
                                    <h5 class="section-subtitle">@Loc["Lbl_Highlights"]</h5>
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach (var link in exp.DisplayHighlights)
                                        {
                                            <a href="@link.Url" target="_blank" class="highlight-link shadow-sm">
                                                <i class="fa-solid fa-link me-1"></i> @link.Name
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private HashSet<ExperienceModel> ListExperiences = new();

    protected override async Task OnInitializedAsync()
    {
        ListExperiences = await PortfolioService.GetExperiencesAsync();
    }
}