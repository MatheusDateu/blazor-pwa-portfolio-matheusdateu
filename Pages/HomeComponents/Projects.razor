@page "/projetos"
@using BlazorDeploy.Models
@using BlazorDeploy.Services
@using Blazored.LocalStorage
@using Microsoft.Extensions.Localization
@inject IPortfolioService PortfolioService
@inject ModalService ModService
@inject ILocalStorageService LocalStorage
@inject NavigationManager NavManager
@inject IStringLocalizer<BlazorDeploy.Resources.App> Loc
@inject IJSRuntime JSRuntime

@inherits ComponentBase

<section id="projetos" class="section-projects">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3 animate-up">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="fa-solid fa-folder-open me-2"></i>@Loc["Lbl_Projects"]
                </h2>
                <p class="text-muted m-0 mt-1">@Loc["Lbl_ProjectsDescription"]</p>
            </div>

            @if (HasActiveFilters)
            {
                <button class="btn btn-outline-danger btn-sm rounded-pill align-self-start align-self-md-center shadow-sm" @onclick="ClearFilters">
                    <i class="fa-solid fa-trash-can me-1"></i> @Loc["Btn_ClearFilter"]
                </button>
            }
        </div>

        <div class="filter-panel p-4 mb-5 rounded-3 bg-white shadow-sm animate-up delay-1">
            <div class="row g-3">
                <div class="col-12 col-md-8">
                    <div class="input-group search-box shadow-sm rounded-pill px-3 bg-light border">
                        <span class="input-group-text border-0 bg-transparent text-muted">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </span>
                        <input type="text" class="form-control border-0 bg-transparent text-dark py-2"
                               placeholder="@Loc["Plh_SearchBar"]"
                               @bind-value="SearchQuery" @bind-value:event="oninput" @onkeyup="SaveFiltersToStorage" />
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <select class="form-select custom-select shadow-sm rounded-pill px-4 bg-light border py-2 text-secondary" @bind="SelectedCategoryFilter" @bind:after="SaveFiltersToStorage">
                        <option value="">@Loc["Sel_AllOptions"]</option>
                        @if (Categories != null)
                        {
                            @foreach (var cat in Categories)
                            {
                                <option value="@cat.Id.ToString()">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        @if (FilteredProjectsByCategory == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Loc["Lbl_Loading"]...</span>
                </div>
            </div>
        }
        else if (!FilteredProjectsByCategory.Any())
        {
            <div class="card p-5 text-center rounded-3 border-0 bg-white shadow-sm animate-up delay-2">
                <div class="card-body">
                    <i class="fa-solid fa-diagram-project fa-2x mb-3 text-muted"></i>
                    <p class="m-0 text-muted fw-medium">@Loc["Lbl_FilteredProjectNotFound"]</p>
                </div>
            </div>
        }
        else
        {
            <div class="accordion custom-accordion animate-up delay-2" id="projectAccordion">
                @foreach (var group in FilteredProjectsByCategory)
                {
                    var categoryName = group.Key;
                    var categoryId = Categories.FirstOrDefault(c => c.Name == categoryName)?.Id ?? 0;
                    var projects = group.Value;
                    var isFirst = group.Key == FilteredProjectsByCategory.Keys.First();

                    <div class="accordion-item mb-3 shadow-sm rounded overflow-hidden">
                        <h2 class="accordion-header" id="heading-cat-@categoryId">
                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapse-cat-@categoryId"
                                    aria-expanded="@(isFirst ? "true" : "false")" aria-controls="collapse-cat-@categoryId">
                                <div class="d-flex justify-content-between w-100 align-items-center pe-3">
                                    <span>📂 <strong class="ms-1">@categoryName</strong></span>
                                    <span class="badge bg-primary rounded-pill px-3 py-2">@projects.Count</span>
                                </div>
                            </button>
                        </h2>

                        <div id="collapse-cat-@categoryId" class="accordion-collapse collapse @(isFirst ? "show" : "")"
                             aria-labelledby="heading-cat-@categoryId" data-bs-parent="#projectAccordion">
                            <div class="accordion-body bg-white p-4">
                                <div class="row g-4">
                                    @foreach (var projeto in projects)
                                    {
                                        <div class="col-12 col-md-6">
                                            <div class="card h-100 border-0 border-start border-4 border-primary shadow-sm card-tech d-flex flex-column">
                                                <div class="card-body p-4 flex-grow-1">
                                                    <h4 class="h5 fw-bold text-primary mb-2" title="@projeto.Name">@projeto.Name</h4>
                                                    <p class="small text-secondary line-clamp-3 mb-0" title="@projeto.Synopsis">@projeto.Synopsis</p>
                                                </div>
                                                <div class="card-footer bg-transparent border-0 px-4 pb-4 pt-0 mt-auto">
                                                    <button class="btn btn-outline-custom btn-sm w-100 rounded-pill"
                                                            @onclick="() => ModService.Show(projeto)">
                                                        @Loc["Lbl_LearnMore"]
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>